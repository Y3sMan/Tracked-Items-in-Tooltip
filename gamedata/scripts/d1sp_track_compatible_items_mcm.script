-- TODO: we could support separate colours per type, or separate colours per armour/weapon
--       but for now we will just support allowing the main colour to be configurable and
--       all compatible items will use this same colour
local COMPAT_CLR = clr_presets[PRESET_GOLD] -- default

-- TODO: We could add support for different colours per type
local TYPE_UPGRADE = "upgrade"
local TYPE_PART = "part"
local TYPE_ATTACHMENT = "attachment"
local TYPE_AMMO = "ammo"
local TYPE_REPAIR = "repair"

local KIND_UPGRADE = "i_upgrade"
local KIND_PART = "i_part"
local KIND_AMMO = "w_ammo"

--[[
    [kobra] is an [addon] and is marked as w_misc
    as are other scopes

    'i_attach' is actually for armour attachments so don't use that
]]
local KIND_ATTACHMENT = "w_misc"

local KIND_REPAIR = "i_repair"

local kind_type_map = {
    [KIND_UPGRADE] = TYPE_UPGRADE,
    [KIND_PART] = TYPE_PART,
    [KIND_ATTACHMENT] = TYPE_ATTACHMENT,
    [KIND_AMMO] = TYPE_AMMO,
    [KIND_REPAIR] = TYPE_REPAIR,
}

local DEBUG = "debug"
local INFO = "info"

-- NOTE: debug logs will lag the game
local enable_debug = false
local enable_info = false

local function print_dbg(type, func_name, fmt, ...)
    if (type == DEBUG and enable_debug) or
        (type == INFO and enable_info) then
        printf(string.format("- [d1sp] [%s] [%s] | ", type, func_name) .. fmt, ...)
    end
end

local function log_section_kind(type, func_name, msg, section, kind)
    print_dbg(type, func_name, "'%s' - section: [%s] - kind: [%s]", msg, section, kind)
end

local function clear_table(table)
    if not table then
        return
    end
    for i = 1, #table do
        table[i] = nil
    end
end

local function flatten(tbl)
    if tbl and type(tbl) == "table" then
        return table.concat(tbl, ",")
    else
        return "<nil>"
    end
end

--[[
    Get a section or its parent section

    This is required because items **can** change name/section if attachments are added

    For example the ltx will have the following:

    [wpn_ak74u]
    parent_section                           = wpn_ak74u
    [wpn_ak74u_kobra]:wpn_ak74u

    where [wpn_ak74u_kobra] is just [wpn_ak74u] with a scope attached

    The issue however stems from us needing to track a unique name for compatible items, and if we used
    [wpn_ak74u_kobra] instead of [wpn_ak74u], then if someone removes the scope then the 'track item' menu
    will become available as technically the base (parent) is not tracked
    As such we *always* track against parent if available
]]
local function section_or_parent(obj)
    if not obj then
        return nil
    end
    local section = obj:section()
    if not section then
        return nil
    end
    local parent = ini_sys:r_string_ex(section, "parent_section") or "not_found"
    if parent and parent ~= "not_found" then
        section = parent
    end
    return section
end

local allowed_containers = {
    "actor_equ",
    "actor_belt",
    "actor_bag",
    "actor_trade_bag",
    "actor_trade",
    "npc_bag",
    "npc_trade",
    "npc_trade_bag"
}

local allowed_modes = {
    "inventory",
    "trade",
    "loot"
}

local configured_types = {
    [TYPE_UPGRADE] = true,
    [TYPE_PART] = true,
    [TYPE_ATTACHMENT] = true,
    [TYPE_AMMO] = true,
    [TYPE_REPAIR] = true
}

local tracked_bags = {
    ["actor_bag"] = true,
    ["actor_trade"] = true,
    ["actor_trade_bag"] = true,
    ["npc_bag"] = true,
    ["npc_trade"] = true,
    ["npc_trade_bag"] = true
}

local supported_kinds = {
    [TYPE_UPGRADE] = {
        ["w_sniper"] = true,
        ["w_rifle"] = true,
        ["w_smg"] = true,
        ["w_shotgun"] = true,
        ["w_pistol"] = true,
        ["o_helmet"] = true,
        ["o_heavy"] = true,
        ["o_sci"] = true,
        ["o_medium"] = true,
        ["o_light"] = true
    },
    [TYPE_PART] = {
        ["w_sniper"] = true,
        ["w_rifle"] = true,
        ["w_smg"] = true,
        ["w_shotgun"] = true,
        ["w_pistol"] = true,
        ["o_helmet"] = true,
        ["o_heavy"] = true,
        ["o_sci"] = true,
        ["o_medium"] = true,
        ["o_light"] = true
    },
    [TYPE_ATTACHMENT] = {
        ["w_sniper"] = true,
        ["w_rifle"] = true,
        ["w_smg"] = true,
        ["w_shotgun"] = true,
        ["w_pistol"] = true,
    },
    [TYPE_AMMO] = {
        ["w_sniper"] = true,
        ["w_rifle"] = true,
