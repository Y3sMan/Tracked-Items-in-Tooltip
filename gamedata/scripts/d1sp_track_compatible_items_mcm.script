-- RIGHT CLICK MENU ITEMS
-------------------------

local function translate(key)
    print_dbg(INFO, "translate", "key: [%s]", key or "<nil>")
    if not key then
        return "<localization-not-found>"
    end
    return game.translate_string(key)
end

-- track

function ui_inventory.UIInventory:D1sp_Track_Name(obj, bag, temp, type)
    print_dbg(INFO, "D1sp_Track_Name", "type: [%s]", type)
    if type == TYPE_UPGRADE then
        return translate("d1sp_track_compatible_items_track_upgrade_kits")
    elseif type == TYPE_PART then
        return translate("d1sp_track_compatible_items_track_parts")
    elseif type == TYPE_ATTACHMENT then
        return translate("d1sp_track_compatible_items_track_attachments")
    elseif type == TYPE_AMMO then
        return translate("d1sp_track_compatible_items_track_ammo")
    elseif type == TYPE_REPAIR then
        return translate("d1sp_track_compatible_items_track_repair_tools")
    end
    return "<not-found>"
end

function ui_inventory.UIInventory:D1sp_Track_Cond(obj, bag, temp, type)
    print_dbg(INFO, "D1sp_Track_Cond", "type: [%s]", type)
    obj = self:CheckItem(obj, "D1sp_Track_Cond")
    if not obj then
        return
    end
    return can_obj_be_tracked(obj, type)
end

function ui_inventory.UIInventory:D1sp_Track_Action(obj, bag, temp, type)
    print_dbg(INFO, "D1sp_Track_Action", "type: [%s]", type)
    obj = self:CheckItem(obj, "D1sp_Track_Action")
    if not obj then
        return
    end
    if can_obj_be_tracked(obj, type) then
        local section = section_or_parent(obj)
        if section then
            track_item(section, type, obj)
        end
    end
end

-- untrack

function ui_inventory.UIInventory:D1sp_Untrack_Name(obj, bag, temp, type)
    print_dbg(INFO, "D1sp_Untrack_Name", "type: [%s]", type)
    if type == TYPE_UPGRADE then
        return translate("d1sp_track_compatible_items_untrack_upgrade_kits")
    elseif type == TYPE_PART then
        return translate("d1sp_track_compatible_items_untrack_parts")
    elseif type == TYPE_ATTACHMENT then
        return translate("d1sp_track_compatible_items_untrack_attachments")
    elseif type == TYPE_AMMO then
        return translate("d1sp_track_compatible_items_untrack_ammo")
    elseif type == TYPE_REPAIR then
        return translate("d1sp_track_compatible_items_untrack_repair_tools")
    end
    return "<not-found>"
end

function ui_inventory.UIInventory:D1sp_Untrack_Cond(obj, bag, temp, type)
    print_dbg(INFO, "D1sp_Untrack_Cond", "type: [%s]", type)
    obj = self:CheckItem(obj, "D1sp_Untrack_Cond")
    if not obj then
        return
    end
    return can_obj_be_untracked(obj, type)
end

function ui_inventory.UIInventory:D1sp_Untrack_Action(obj, bag, temp, type)
    print_dbg(INFO, "D1sp_Untrack_Action", "type: [%s]", type)
    obj = self:CheckItem(obj, "D1sp_Untrack_Action")
    if not obj then
        return
    end
    if can_obj_be_untracked(obj, type) then
        local section = section_or_parent(obj)
        if section then
            untrack_item(section, type, obj)
        end
    end
end

-- clear all trackers

function ui_inventory.UIInventory:D1sp_Clear_Upgrade_Trackers_Name(obj, bag, temp)
    print_dbg(INFO, "D1sp_Clear_Upgrade_Trackers_Name", "")
    return translate("d1sp_track_compatible_items_clear_trackers")
end

function ui_inventory.UIInventory:D1sp_Clear_Upgrade_Trackers_Cond(obj, bag, temp)
    print_dbg(INFO, "D1sp_Clear_Upgrade_Trackers_Cond", "")
    obj = self:CheckItem(obj, "D1sp_Clear_Upgrade_Trackers_Cond")
    if not obj then
        return
    end
    local section = section_or_parent(obj)
    if not section then
        return
    end
    local kind = SYS_GetParam(0, section, "kind", "not_found")
    if not kind or kind == "not_found" then
        return
    end
    local type = kind_type_map[kind]
    return type and obj_can_be_cleared(obj, type)
end

function ui_inventory.UIInventory:D1sp_Clear_Upgrade_Trackers_Action(obj, bag, temp)
    print_dbg(INFO, "D1sp_Clear_Upgrade_Trackers_Action", "")
    obj = self:CheckItem(obj, "D1sp_Clear_Upgrade_Trackers_Cond")
    if not obj then
        return
    end
    local section = section_or_parent(obj)
    if not section then
        return
    end
    local kind = SYS_GetParam(0, section, "kind", "not_found")
    if not kind or kind == "not_found" then
        return
    end
    local type = kind_type_map[kind]
    if type and obj_can_be_cleared(obj, type) then
        local items = inverse_compatible_item_to_item_tracker[section]
        if type and items and #items > 0 then
            local tmp = dup_table(items)
            print_dbg(INFO, "clearing items: [%s] for compatible item: [%s]", flatten(tmp), section)
            for i = 1, #tmp do
                -- NOTE: calling into this modifies the table 'items'
                --       thats why we make a copy
                untrack_item(tmp[i], type, obj)
            end
        end
    end
end

-------------------------
-- GAME SAVE
-------------------------

-- NOTE: mod renamed to 'track compatible items' from v0.0.1 to v0.0.2
--       key format was retained and 'd1sp_track_compatible_item_upgrades_data_v1'
--       is taken from the old version for backwards compatibility reasons
--
-- versionned incase we want to change format
local DATA_KEY_UPGRADES_V1 = "d1sp_track_compatible_item_upgrades_data_v1";
local DATA_KEY_PARTS_V1 = "d1sp_track_compatible_item_parts_data_v1";
local DATA_KEY_ATTACHMENTS_V1 = "d1sp_track_compatible_item_attachments_data_v1";
local DATA_KEY_AMMO_V1 = "d1sp_track_compatible_item_ammo_data_v1";
local DATA_KEY_REPAIR_V1 = "d1sp_track_compatible_item_repair_tools_data_v1";

local data_keys = {
    [TYPE_UPGRADE] = DATA_KEY_UPGRADES_V1,
    [TYPE_PART] = DATA_KEY_PARTS_V1,
    [TYPE_ATTACHMENT] = DATA_KEY_ATTACHMENTS_V1,
    [TYPE_AMMO] = DATA_KEY_AMMO_V1,
    [TYPE_REPAIR] = DATA_KEY_REPAIR_V1
}

local function handle_save_state(mdata)
    if not mdata then
        return
    end

    -- NOTE: separate so we can 'clean up' the trackers and cache on each load
    print_dbg(INFO, "handle_save_state", "saving ...")

    for type, enabled in pairs(configured_types) do
        local key = data_keys[type]
        if key and enabled then
            local items = {}
            for item_name, is_tracked in pairs(tracked_items[type]) do
                if is_tracked then
                    print_dbg(INFO, "handle_save_state", "saving tracker for item: [%s] and type: [%s]", item_name, type)
                    items[#items + 1] = item_name
                end
            end
            mdata[key] = items or {}
        end
    end

    -- Don't save the cache. This way we can fix issues with new items
    -- being added without doing anything.

    print_dbg(INFO, "handle_save_state", "saved!")
end

local function handle_load_state(mdata)
    if not mdata then
        return
    end

    -- TODO: What happens if someone tracks a gun/armour from a mod and then removes it?
    --       We could add a 'reset on load' option to MCM that can be ticked and
    --         will reset all tracking
    print_dbg(INFO, "handle_load_state", "loading ...")

    for type, enabled in pairs(configured_types) do
        local key = data_keys[type]
        if key and enabled then
            local data = mdata[key]
            if data then
                print_dbg(INFO, "handle_load_state", "found save data for key: [%s] type: [%s] data: [%s]", key, type,
                    flatten(data))
                for i = 1, #data do
                    local item = data[i]
                    print_dbg(INFO, "handle_load_state", "loading tracker for item: [%s] and type: [%s]", item, type)
                    track_item(item, type)
                end
            end
        end
    end

    print_dbg(INFO, "handle_save_state", "loaded!")
end

-------------------------
-- CALLBACKS
-------------------------

local initialized = false

local function get_properties_index(gui)
    -- For some reason setting the index of new items via #(gui.properties) + 1
    -- doesn't set the correct index
    -- instead we iterate the menu items and manually find the highest index and
    -- use that + 1
    local i = 1
    for key, tbl in pairs(gui.properties) do
        print_dbg(DEBUG, "get_properties_index", "found menu item: [%s] index: [%s]", key, i)
        i = math.max(i, tbl.index)
    end
    print_dbg(DEBUG, "get_properties_index", "found max index: %s", i)
    return i + 1
end

local function handle_GUI_on_show()
    if not initialized then
        print_dbg(INFO, "handle_GUI_on_show", "initializing menu items")

        local gui = GetActorMenu()

        -- Options for menu items:
        -- key --> value
        -- key is an ID for the menu item (not its display name)
        -- value is a table of:
        -- {
        --     [1] ["index"] = its index in the list (number)
        --     [2] ["name"] = the lookup key of the name
        --         or ["name_func"] = name of UIInventory member function to get above
        --     [3] ["mode"] = a table of modes the option is available in
        --                    {"inventory","loot","trade"}
        --         or ["mode_func"] = name of UIInventory member function to get above
        --     [4] ["cont"] = a table of containers its available in
        --                    {"actor_equ","actor_belt"}
        --         or ["cont_func"] = name of UIInventory member function to get above
        --     [5] ["precondition"] = condition for it to show
        --     [6] ["action"] = function to call on clicking it
        -- }

        print_dbg(INFO, "handle_GUI_on_show", "configuring new menu items")

        for type, enabled in pairs(configured_types) do
            if enabled then
                -- t2k_table appears to convert a table list { keys } into { key = true }
                gui.properties["d1sp_trk_compat_itms_track" .. "_" .. type] = {
                    index = get_properties_index(gui),
                    name_func = { "D1sp_Track_Name", type },
                    mode = t2k_table(dup_table(allowed_modes)),
                    cont = t2k_table(dup_table(allowed_containers)),
                    precondition1 = { "D1sp_Track_Cond", type },
                    action = { "D1sp_Track_Action", type }
                }
                gui.properties["d1sp_trk_compat_itms_untrack" .. "_" .. type] = {
                    index = get_properties_index(gui),
                    name_func = { "D1sp_Untrack_Name", type },
                    mode = t2k_table(dup_table(allowed_modes)),
                    cont = t2k_table(dup_table(allowed_containers)),
                    precondition1 = { "D1sp_Untrack_Cond", type },
                    action = { "D1sp_Untrack_Action", type }
                }
                print_dbg(INFO, "handle_GUI_on_show", "initialized menu items for type: [%s]", type)
            end
        end

        gui.properties["d1sp_trk_compat_itms_track_clear"] = {
            index = get_properties_index(gui),
            name_func = { "D1sp_Clear_Upgrade_Trackers_Name", type },
            mode = t2k_table(dup_table(allowed_modes)),
            cont = t2k_table(dup_table(allowed_containers)),
            precondition1 = { "D1sp_Clear_Upgrade_Trackers_Cond", type },
            action = { "D1sp_Clear_Upgrade_Trackers_Action", type }
        }

        print_dbg(INFO, "handle_GUI_on_show", "menu items initialized")

        initialized = true
    end
end

-------------------------
-- INIT
-------------------------

function on_game_start()
    RegisterScriptCallback("GUI_on_show", handle_GUI_on_show)
    RegisterScriptCallback("load_state", handle_load_state)
    RegisterScriptCallback("save_state", handle_save_state)

    -- mcm
    load_settings()
    RegisterScriptCallback("on_option_change", handle_on_option_change)
end

-------------------------
-- MCM
-------------------------

local mod_name = "d1sp_track_compatible_items"

local function read_settings()
    local mcm = ui_mcm
    if mcm then
        -- GOLD
        COMPAT_CLR = GetARGB(
            50,
            mcm.get(mod_name .. "/common_clr_red") or 255,
            mcm.get(mod_name .. "/common_clr_green") or 215,
            mcm.get(mod_name .. "/common_clr_blue") or 0)

        local common_clr_preset = mcm.get(mod_name .. "/common_clr_preset")
        if common_clr_preset and common_clr_preset ~= PRESET_NONE then
            local preset = clr_presets[common_clr_preset]
            if preset then
                COMPAT_CLR = preset
            end
        end
    end
end

function load_settings()
    read_settings()
end

function handle_on_option_change(state)
    if state then
        read_settings()
    end
end

function on_mcm_load()
    local options_tree = {
        -- NOTE: [val] determines how the value is casted - 0=string, 1=bool, 2=number/float
        id = mod_name,
        text = "ui_mcm_d1sp_track_compatible_items_tab_title",
        sh = true,
        gr = {
            {
                id = "banner",
                type = "slide",
                text = "ui_mcm_d1sp_track_compatible_items_banner",
                size = { 512, 50 },
                spacing = 20
            },
            -- Preset desc
            {
                id = "preset_desc",
                type = "desc",
                clr = { 200, 200, 255, 200 },
                text = "ui_mcm_d1sp_track_compatible_items_common_clr_preset_desc"
            },
            -- common colour preset
            {
                id = "common_clr_preset",
                type = "list",
                val = 0,
                def = PRESET_NONE,
                content = clr_preset_mcm_list
            },
            { id = "divider", type = "line" },
            -- common colour config
            {
                id = "common_clr_desc",
                type = "desc",
                clr = { 200, 200, 255, 200 },
                text = "ui_mcm_d1sp_track_compatible_items_common_clr_desc"
            },
            {
                id = "common_clr_red",
                text = "ui_mcm_d1sp_track_compatible_items_common_clr_red",
                type = "track",
                val = 2,
                min = 0,
                max = 255,
                step = 1,
                def = 220
            },
            {
                id = "common_clr_green",
                text = "ui_mcm_d1sp_track_compatible_items_common_clr_green",
                type = "track",
                val = 2,
                min = 0,
                max = 255,
                step = 1,
                def = 20
            },
            {
                id = "common_clr_blue",
                text = "ui_mcm_d1sp_track_compatible_items_common_clr_blue",
                type = "track",
                val = 2,
                min = 0,
                max = 255,
                step = 1,
                def = 60
            }
        }
    }
    return options_tree
end
