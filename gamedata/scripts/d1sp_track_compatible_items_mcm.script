    [PRESET_PEACH] = GetARGB(50, 255, 218, 185),
    [PRESET_VIOLET] = GetARGB(50, 238, 130, 238),
    [PRESET_PALE_GREEN] = GetARGB(50, 152, 251, 152),
    [PRESET_SEA_GREEN] = GetARGB(50, 32, 178, 170),
