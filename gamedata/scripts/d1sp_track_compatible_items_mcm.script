local function is_kind_supported(kind, type)
    return supported_kinds[type][kind]
end

-- Whether we are tracking an item (gun or armour)
-- format: [section_name] = true
local tracked_items = {
    [TYPE_UPGRADE] = {},
    [TYPE_PART] = {},
    [TYPE_ATTACHMENT] = {},
    [TYPE_AMMO] = {},
    [TYPE_REPAIR] = {}
}

-- A cache of compatible upgrades for each tracked item
-- so we don't need to look them up each hover check
-- format: [name] = { list of compatble upgrade names }
local item_compatible_items_cache = {
    [TYPE_UPGRADE] = {},
    [TYPE_PART] = {},
    [TYPE_ATTACHMENT] = {},
    [TYPE_AMMO] = {},
    [TYPE_REPAIR] = {}
}

-- tracks compatible items to items they are for so we can work backwards if needed
-- format: [upgrade, part, attachment or ammo] = { "item1", "item2", etc }
local inverse_compatible_item_to_item_tracker = {}

-------------------------
-- TRACKING UTILS
-------------------------

local function is_item_tracked(section_name, type)
    if not section_name then
        return
    end
    if not type then
        return
    end
    return tracked_items[type][section_name]
end

local function can_obj_be_tracked(obj, type)
    if not obj then
        return false
    end
    local section = section_or_parent(obj)
    if not section then
        return false
    end
    local kind = SYS_GetParam(0, section, "kind", "not_found")
    if not kind or kind == "not_found" then
        return false
    end
    if not is_kind_supported(kind, type) then
        log_section_kind(INFO, "can_obj_be_tracked", "invalid kind", section, kind)
        return false
    end
    if is_item_tracked(section, type) then
        log_section_kind(INFO, "can_obj_be_tracked", "obj already tracked", section, kind)
        return false
    end
    log_section_kind(INFO, "can_obj_be_tracked", "obj can be tracked", section, kind)
    return true
end

local function can_obj_be_untracked(obj, type)
    if not obj then
        return false
    end
    local section = section_or_parent(obj)
    if not section then
        return false
    end
    local kind = SYS_GetParam(0, section, "kind", "not_found")
    if not kind or kind == "not_found" then
        return false
    end
    if not is_kind_supported(kind, type) then
        log_section_kind(INFO, "can_obj_be_tracked", "invalid kind", section, kind)
        return false
    end
    if not is_item_tracked(section, type) then
        log_section_kind(INFO, "can_obj_be_tracked", "obj isn't tracked", section, kind)
        return false
    end
    log_section_kind(INFO, "can_obj_be_tracked", "obj can be untracked", section, kind)
    return true
end

local function mark_tracked(section_name, type)
    if not section_name then
        return
    end
    print_dbg(INFO, "mark_tracked", "tracking item: [%s]", section_name)
    tracked_items[type][section_name] = true
end

local function mark_untracked(section_name, type)
    if not section_name then
        return
    end
    print_dbg(INFO, "mark_tracked", "untracking item: [%s]", section_name)
    tracked_items[type][section_name] = false
end

--[[
    Get all the upgrades associated with the item

    Returns format:
    {
        { "upg_1", ... },
        { "upg_2", ...}
    }
]]
local function get_item_upgrades(section_name)
    local parse_sec = section_name
    local section = section_name
    local upgrades = nil
    local parent = ini_sys:r_string_ex(section, "parent_section") or "not_found"
    if parent and parent ~= "not_found" then
        -- look for upgrades on parent
        print_dbg(INFO, "get_item_upgrades", "found parent_section for gun: [%s]", section)
        upgrades = SYS_GetParam(0, parent, "upgrades", "not_found")
        parse_sec = parent
    else
        -- look for upgrades on this
        upgrades = SYS_GetParam(0, section, "upgrades", "not_found")
    end

    if upgrades and upgrades ~= "" then
        print_dbg(INFO, "get_item_upgrades", "found upgrades for tracked item: [%s] - [%s]", section, upgrades)
        -- copied and modified from itms_manager --> ActorMenu_on_item_focus_receive [Upgrade parts]
        local parsed_upgrades = parse_list(ini_sys, parse_sec, "upgrades")
        print_dbg(INFO, "get_item_upgrades", "parsed upgrades: [%s]", flatten(parsed_upgrades))
        local out_tbl = {}
        for i = 1, #parsed_upgrades do
            print_dbg(INFO, "get_item_upgrades", "extracting upgrade kits for: [%s]", parsed_upgrades[i])
            itms_manager.extract_upgr_tools(out_tbl, parsed_upgrades[i])
        end
        local result = {}
        for key, value in pairs(out_tbl) do
            result[#result + 1] = key
        end
        print_dbg(INFO, "get_item_upgrades", "parsed upgrade kits: [%s]", flatten(result))
        return result
    else
        print_dbg(INFO, "get_item_upgrades", "could not find an upgrades param for gun: [%s]", section)
    end
    return {}
end

local function get_item_parts(section_name)
    local result = {}
    local parent_sec = ini_sys:r_string_ex(section_name, "parent_section") or section_name
    -- TODO: it may be better to load the ini_parts file in here instead
    local parts_str = itms_manager.ini_parts:r_string_ex("con_parts_list", parent_sec)
    local parts = parts_str and (parts_str ~= "") and str_explode(parts_str, ",")
    if parts then
        for i = 1, #parts do
            print_dbg(INFO, "get_item_parts", "found part: [%s]", parts[i])
            result[#result + 1] = parts[i]
        end
    end
    return result
end

local function get_item_attachments(section_name)
    -- NOTE: We can't have a dependency on 'obj' otherwise setting trackers onload wont work (as we don't have an obj)
    --       as such we use the non-obj based versions of internal utils

    -- NOTE: For future reference, in the ltx definition it appears some guns contain the parameter 'grenade_launcher_name'
    --         while having the parameter 'grenade_launcher_status' == 0
    --       I'm assuming this means the gun cannot have a grenade launcher equipped
    --       But then why is it defined? As far as I can tell in the few cases I've tested
    --         such guns don't always have the ability to add an underbarrel upgrade for the grenade launcher, vepr is an example of this
    --       This means that we cannot check 'grenade_launcher_status' to highlight attachments as some guns will never work for attachment
    --         tracking, like the AKMN. For now I've allowed the current logic of highlighting grenade launcher for the vepr (and others)
    --         as its preferrable to certain guns not working at all.
    --       The same appears to apply for silencers and scopes


    local result = {}

    local parent_sec = ini_sys:r_string_ex(section_name, "parent_section") or section_name

    -- Scopes
    local scopes = parse_list(ini_sys, parent_sec, "scopes")
    for i = 1, #scopes do
        result[#result + 1] = scopes[i]
    end

    local scope = utils_item.get_wpn_param(nil, section_name, "scopes_sect") -- NOTE: can pass nil instead of obj and it will use the section
    if scope then                                                            -- and (obj:weapon_scope_status() == 2) then
        result[#result + 1] = scope
    end

    -- Silencer
    local sil = utils_item.get_wpn_param(nil, section_name, "silencer_name")
    if sil then -- and (obj:weapon_silencer_status() == 2) then
        result[#result + 1] = sil
    end

    -- Grenade Launcher
    local gl = utils_item.get_wpn_param(nil, section_name, "grenade_launcher_name")
    if gl then -- and (obj:weapon_grenadelauncher_status() == 2) then
        result[#result + 1] = gl
    end

    print_dbg(INFO, "get_item_attachments", "attachments: [%s]", flatten(result))

    return result
end

local function get_item_ammo(section_name)         --, obj)
    local result = {}
    local ammo = utils_item.get_ammo(section_name) -- , obj:id()) -- doens't appear to be required by func
    for i = 1, #ammo do
        result[#result + 1] = ammo[i]
    end
    return result
end

local function get_repair_kits(section_name)
    if not section_name then
        return {}
    end

    local result = {}
    local parent_sec = ini_sys:r_string_ex(section_name, "parent_section") or section_name
    -- Repair kits
    local repair_type = ini_sys:r_string_ex(parent_sec, "repair_type")
    if repair_type and repair_type ~= "" then
        local repairs = GetItemList("repair")
        if repairs then
            for kit, v in pairs(repairs) do
                if kit and v and v[repair_type] then
                    result[#result + 1] = kit
                end
            end
        end
        -- Copied from source - may be useful in next version ?
        --[[
        for kit,v in pairs(GetItemList("workshop")) do
            if v[repair_type] then
                focus_tbl[#focus_tbl + 1] = kit
            end
        end
        --]]
    end

    return result
end

--[[
    Clear the upgrade cache for the given item
]]
local function clear_items_upgrade_cache(section_name, type)
    if not section_name then
        return
    end
    print_dbg(INFO, "clear_items_upgrade_cache", "item: [%s] type: [%s] - cache: [%s]", section_name, type,
        flatten(item_compatible_items_cache[type][section_name]))
    local cache = item_compatible_items_cache[type][section_name]
    if cache then
        if #cache > 0 then
            clear_table(item_compatible_items_cache[type][section_name])
            print_dbg(INFO, "clear_items_upgrade_cache", "upgrade cache for: [%s] has been cleared", section_name)
        else
            print_dbg(INFO, "clear_items_upgrade_cache", "upgrade cache for: [%s] was empty", section_name)
        end
    else
        item_compatible_items_cache[type][section_name] = {}
        print_dbg(INFO, "clear_items_upgrade_cache", "no cache found for item: [%s] - new cache created",
            section_name)
    end
end

--[[
    Refresh the upgrade cache for the given item

    section_name = the name of the item
]]
local function refresh_item_upgrade_cache(section_name, type, obj)
    -- NOTE: obj will be <nil> on first load
    --       i was previously passing this variables into the internal funcs for getting compatible
    --       items, but they appear to work without it

    print_dbg(INFO, "refresh_item_upgrade_cache", "item: [%s] type: [%s]", section_name, type)

    if not section_name or not type then
        return
    end

    clear_items_upgrade_cache(section_name, type)

    local items = nil

    if type == TYPE_UPGRADE then
        items = get_item_upgrades(section_name)
    elseif type == TYPE_PART then
        items = get_item_parts(section_name)
    elseif type == TYPE_ATTACHMENT then
        items = get_item_attachments(section_name)
    elseif type == TYPE_AMMO then
        items = get_item_ammo(section_name)
    elseif type == TYPE_REPAIR then
        items = get_repair_kits(section_name)
    end

    if items and #items > 0 then
        print_dbg(INFO, "refresh_item_upgrade_cache", "loaded items: [%s] for section: [%s] and type: [%s]",
            flatten(items),
            section_name, type)

        local cached_upg = item_compatible_items_cache[type][section_name]
        if not cached_upg then
            print_dbg(INFO, "refresh_item_upgrade_cache", "no cache found for item: [%s] - new cache created",
                section_name)
            item_compatible_items_cache[type][section_name] = {}
        end

        for i = 1, #items do
            print_dbg(INFO, "refresh_item_upgrade_cache", "caching item: [%s] against item: [%s]", items[i],
                section_name)
            item_compatible_items_cache[type][section_name][#cached_upg + 1] = items[i]
        end
    end

    return items
end

--[[
    Track an item against a compatible item (this helps us look it up easier later)

    These are not separated by 'type', the table is just one long list of:
    ["compatible item"] = { items that use it }
]]
local function inverse_track_item_against_compatible_item(compatible_item_name, item_name)
    if not compatible_item_name or not item_name then
        return
    end
    print_dbg(INFO, "inverse_track_item_against_compatible_item",
        "attempting to track item: [%s] against compatible item: [%s]",
        item_name,
        compatible_item_name)

    if not inverse_compatible_item_to_item_tracker[compatible_item_name] then
        inverse_compatible_item_to_item_tracker[compatible_item_name] = {}
    end

    local items = inverse_compatible_item_to_item_tracker[compatible_item_name]
    local matched = false
    for i = 1, #items do
        local item = items[i]
        if item == item_name then
            matched = true
            break
        end
    end
    if not matched then
        print_dbg(INFO, "track_item_for_upgrade", "item: [%s] for item: [%s] - tracked", item_name,
            compatible_item_name)
        items[#items + 1] = item_name
    else
        print_dbg(
            INFO,
            "track_item_for_upgrade", "item: [%s] for item: [%s] - tracking skipped - item already tracked",
            item_name, compatible_item_name)
    end
end

local function inverse_untrack_item_from_compatible_item(compatible_item_name, item_name)
    if not compatible_item_name or not item_name then
        return
    end
    if not inverse_compatible_item_to_item_tracker[compatible_item_name] then
        inverse_compatible_item_to_item_tracker[compatible_item_name] = {}
        return
    end

    local items = inverse_compatible_item_to_item_tracker[compatible_item_name]

    local indx = nil -- the indx of the item to remove
    for i = 1, #items do
        local item = items[i]
        if item == item_name then
            indx = i
            break
        end
    end
    if indx then
        -- NOTE: changes the index of other items as it shifts down
        table.remove(items, indx)
        print_dbg(INFO, "inverse_untrack_item_from_compatible_item", "item: [%s] for item: [%s] - untracked",
            item_name,
            compatible_item_name)
    else
        print_dbg(INFO,
            "inverse_untrack_item_from_compatible_item",
            "item: [%s] for item: [%s] - untracking skipped - not currently tracked",
            item_name, compatible_item_name)
    end
end

--[[
    Start tracking upgrades for a gun or armour
]]
local function track_item(section_name, type, obj)
    if not obj then
        print_dbg(INFO, "track_item", "may not be able cannot track item. obj is <nil>. this happens on first load")
        -- don't return - upgrades and parts don't need obj
    end

    if is_item_tracked(section_name, type) then
        print_dbg(INFO, "track_item", "item already tracked: [%s] type: [%s]", section_name)
        return
    end

    -- (1) refresh cache
    local compatible_items = refresh_item_upgrade_cache(section_name, type, obj)

    print_dbg(INFO, "track_item", "found compatible items: [%s]", flatten(compatible_items))

    -- (2) setup a upgrade tracker as well for quick clearing
    if compatible_items and #compatible_items > 0 then
        for i = 1, #compatible_items do
            inverse_track_item_against_compatible_item(compatible_items[i], section_name)
        end
    end

    -- (3) finally set the tracker
    mark_tracked(section_name, type)

    print_dbg(INFO, "track_item", "item: [%s] should now be tracked!", section_name)
end

--[[
    Stop tracking upgrades for a gun or armour
]]
local function untrack_item(section_name, type, obj)
    if not is_item_tracked(section_name, type) then
        print_dbg(INFO, "untrack_item", "item is not tracked: [%s]", section_name)
        return
    end

    -- (1) clear its cache
    clear_items_upgrade_cache(section_name, type)

    -- (2) remove it from the upgrade tracker
    local compatible_items = nil
    if type == TYPE_UPGRADE then
        compatible_items = get_item_upgrades(section_name)
    elseif type == TYPE_PART then
        compatible_items = get_item_parts(section_name)
    elseif type == TYPE_ATTACHMENT and itms_manager.IsWeapon(obj) then
        compatible_items = get_item_attachments(section_name)
    elseif type == TYPE_AMMO and itms_manager.IsWeapon(obj) then
        compatible_items = get_item_ammo(section_name) -- , obj)
    elseif type == TYPE_REPAIR then
        compatible_items = get_repair_kits(section_name)
    end

    if compatible_items and #compatible_items > 0 then
        for i = 1, #compatible_items do
            inverse_untrack_item_from_compatible_item(compatible_items[i], section_name)
        end
    end

    -- (3) finally untrack it
    mark_untracked(section_name, type)

    print_dbg(INFO, "untrack_item", "item: [%s] should now be untracked!", section_name)
end

local function obj_can_be_cleared(obj, type)
    if not obj or not type then
        return false
    end
    local section = section_or_parent(obj)
    if not section then
        return false
    end
    local kind = SYS_GetParam(0, section, "kind", "not_found")
    if kind ~= "not_found" and is_kind_supported(kind, type) then
        return false
    end
    return inverse_compatible_item_to_item_tracker[section] and #(inverse_compatible_item_to_item_tracker[section]) > 0
end

-- export funcs - YM
    -- get functions -- just get a copy of the func/list
    -- return list {}
function get_inverse_compatible_item_to_item_tracker ()
    return inverse_compatible_item_to_item_tracker or {}
end

    -- check functions -- do a single check of key against list
    -- list[key]
    -- return boolean
function check_inverse_compatible_item_to_item_tracker(compatible_item)
    return inverse_compatible_item_to_item_tracker[compatible_item] or false
end

function check_get_item_parts(section_name)
    return get_item_parts(section_name) or {}
end


function check_is_kind_supported(kind, type)
    return is_kind_supported(kind, type) or false
end

function check_is_item_tracked(section_name, type)
    return is_item_tracked(section_name, type) or false
end


-------------------------
-- PATCHES
-------------------------

local original_UICellItem_Highlight = utils_ui.UICellItem.Highlight
function utils_ui.UICellItem:Highlight(state, clr_id, main_clr)
    if state and (not self:IsShown()) and (not self.manual) then
        return
    end

    local highlighted = false
    local section = self.section
    local parent_section = nil
    if section then
        -- TODO: required due to attachment changing name of item
        local parent = ini_sys:r_string_ex(section, "parent_section") or "not_found"
        if parent and parent ~= "not_found" then
            parent_section = parent
        end
        local kind = SYS_GetParam(0, section, "kind", "not_found")
        local type = nil
        local sect = parent_section or section

        if kind and kind ~= "not_found" then
            type = kind_type_map[kind]
        end

        print_dbg(DEBUG, "utils_ui.UICellItem.Highlight", "type: [%s] kind: [%s] section: [%s]", type, kind, sect)

        if tracked_bags[self.container.ID] then
            if type and (type == TYPE_UPGRADE or type == TYPE_PART or type == TYPE_ATTACHMENT or type == TYPE_AMMO or type == TYPE_REPAIR) then
                print_dbg(DEBUG, "utils_ui.UICellItem.Highlight",
                    "attempting to highlight - type: [%s] kind: [%s] section: [%s]", type, kind, sect)

                local cache = inverse_compatible_item_to_item_tracker[sect]
                if not cache or #cache == 0 then
                    print_dbg(DEBUG, "utils_ui.UICellItem.Highlight", "compatible item: [%s] is not tracked - skipping",
                        sect)
                else
                    print_dbg(DEBUG, "utils_ui.UICellItem.Highlight",
                        "compatible item: [%s] is tracked - items in cache: [%s]",
                        sect,
                        #cache)

                    for i = 1, #cache do
                        local item = cache[i]
                        if tracked_items[type][item] then
                            print_dbg(
                                DEBUG,
                                "utils_ui.UICellItem.Highlight",
                                "highlighting item: [%s] from item: [%s] being tracked",
                                sect,
                                item)

                            highlighted = true
                            self.hl:Show(true)
                            self.hl:SetTextureColor(COMPAT_CLR)
                        end
                    end
                end
            end
        end
    end

    if not highlighted then
        original_UICellItem_Highlight(self, state, clr_id, main_clr)
    end
end

